@model MadarfigyeloWeb.Models.Odu

@{
    ViewData["Title"] = "Létrehozás";
}

<h1>Létrehozás</h1>

<h4>Odu</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
