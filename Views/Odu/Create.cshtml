            </div>
            <div class="form-group">
                <label asp-for="OdutTartoNovenyfaj" class="control-label"></label>
                <input asp-for="OdutTartoNovenyfaj" class="form-control" />
                <span asp-validation-for="OdutTartoNovenyfaj" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MagassagMeter" class="control-label"></label>
                <input asp-for="MagassagMeter" class="form-control" />
                <span asp-validation-for="MagassagMeter" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Létrehozás" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Vissza a listához</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
