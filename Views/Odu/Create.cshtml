            </div>
            <div class="form-group">
                <label asp-for="GpsLongitude" class="control-label"></label>
                <input asp-for="GpsLongitude" class="form-control" />
                <span asp-validation-for="GpsLongitude" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Elohelykod" class="control-label"></label>
                <input asp-for="Elohelykod" class="form-control" />
                <span asp-validation-for="Elohelykod" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MireVanHelyezve" class="control-label"></label>
                <input asp-for="MireVanHelyezve" class="form-control" />
                <span asp-validation-for="MireVanHelyezve" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FelhelyezesModja" class="control-label"></label>
                <input asp-for="FelhelyezesModja" class="form-control" />
