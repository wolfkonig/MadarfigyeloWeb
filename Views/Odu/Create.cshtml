            </div>
            <div class="form-group">
                <label asp-for="OdutelepId" class="control-label">OdutelepAzonosito</label>
                <select asp-for="OdutelepId" class ="form-control" asp-items="ViewBag.OdutelepId"></select>
            </div>
            <div class="form-group">
                <label asp-for="OduTipus" class="control-label"></label>
                <input asp-for="OduTipus" class="form-control" />
                <span asp-validation-for="OduTipus" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BejaratiNyilasMm" class="control-label"></label>
