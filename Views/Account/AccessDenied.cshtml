@{
    ViewData["Title"] = "Access Denied";
}

<div class="text-center mt-5">
    <h1 class="display-4 text-danger">Access Denied</h1>
    <p class="lead">You do not have permission to access this resource.</p>
    <hr />
    <p>
        Please <a asp-controller="Account" asp-action="Login">log in</a> with an authorized account or 
        <a asp-controller="Home" asp-action="Index">return to the home page</a>.
    </p>
</div>
