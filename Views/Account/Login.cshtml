@model MadarfigyeloWeb.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Bejelentkezés";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <h2 class="text-center mb-4">@ViewData["Title"]</h2>
        
        <form asp-action="Login" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="name@example.com" autocomplete="username" />
                <label asp-for="Email"></label>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Password" class="form-control" placeholder="Jelszó" autocomplete="current-password" />
                <label asp-for="Password"></label>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">
                    Emlékezz rám
                </label>
            </div>
            
            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">Bejelentkezés</button>
            </div>
        </form>
        
        <div class="mt-3 text-center">
            <p>
                Még nincs fiókod? <a asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]">Regisztrálj</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
